{
  "experiment": {
    "name": "opencode_repeat_smoke_local",
    "seed": 20260523,
    "repeats": 2,
    "output_dir": "runs/opencode_repeat_smoke_local"
  },
  "programbench": {
    "task_list": "configs/task_splits/smoke_local_1.json",
    "no_internet": true,
    "workspace_root": "workspaces",
    "scoring_command": [
      "python",
      "{repo_root}/scripts/reference_scorer.py",
      "{workspace}"
    ]
  },
  "agent": {
    "runtime": "opencode",
    "version": "local-reference",
    "model": "opencode-repeat-local-reference",
    "model_version": "local-reference",
    "max_steps": 8,
    "timeout_seconds": 30,
    "command": [
      "python",
      "{repo_root}/scripts/opencode_agent_reference.py"
    ]
  },
  "conditions": [
    {
      "condition": "clean_skill_clean_verifier",
      "target_level": "none",
      "verifier_exposure_condition": "opencode_skill"
    },
    {
      "condition": "adaptive_full_medium",
      "target_level": "medium",
      "verifier_exposure_condition": "opencode_skill",
      "cost_proxy": {
        "source": "opencode_verifier_call_proxy_v6_rolling_feedback_length",
        "units_per_verifier_call": 3.5,
        "initial_free_calls": 2,
        "require_candidate": true,
        "response_chars_per_unit": 1000.0,
        "projected_response_chars": 1000,
        "response_projection_mode": "rolling_mean",
        "response_projection_floor": 320,
        "response_projection_window": 3
      }
    }
  ]
}
