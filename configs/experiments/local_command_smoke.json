{
  "experiment": {
    "name": "local_command_smoke",
    "seed": 20260522,
    "output_dir": "runs/local_command_smoke"
  },
  "programbench": {
    "task_list": "configs/task_splits/smoke_local.json",
    "no_internet": true,
    "workspace_root": "workspaces",
    "scoring_command": [
      "python",
      "{repo_root}/scripts/reference_scorer.py",
      "{workspace}"
    ]
  },
  "agent": {
    "runtime": "local_command",
    "version": "local-reference",
    "model": "local-command-local-reference",
    "model_version": "local-reference",
    "max_steps": 1,
    "timeout_seconds": 30,
    "command": [
      "python",
      "{repo_root}/scripts/local_agent_reference.py"
    ]
  },
  "conditions": [
    {
      "condition": "no_attack",
      "target_level": "none",
      "verifier_exposure_condition": "no_mention"
    },
    {
      "condition": "clean_verifier",
      "target_level": "none",
      "verifier_exposure_condition": "light_prompt"
    }
  ]
}
